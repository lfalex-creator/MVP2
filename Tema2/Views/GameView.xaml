<Page x:Class="Tema2.Views.GameView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Tema2.Views"
      xmlns:ctx="clr-namespace:Tema2.VMs"
      xmlns:converters="clr-namespace:Tema2.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="GameView"
      PreviewKeyDown="RevealLetter"
      Focusable="True"
      Loaded="Page_Loaded">
    <Page.DataContext>
        <ctx:GameVM/>
    </Page.DataContext>

    <Page.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Width" Value="17"/>
        </Style>
        <converters:ColourEnumConverter x:Key="ColourEnumConverter"/>
    </Page.Resources>
    <Page.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveGameCommand}"/>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenGameCommand}"/>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewGameCommand}"/>
        <KeyBinding Key="H" Modifiers="Control" Command="{Binding ShowStatisticsCommand}"/>

        <KeyBinding Key="A" Modifiers="Control" Command="{Binding SelectNewCategoryCommand}" CommandParameter="All"/>
        <KeyBinding Key="C" Modifiers="Control" Command="{Binding SelectNewCategoryCommand}" CommandParameter="Cars"/>
        <KeyBinding Key="M" Modifiers="Control" Command="{Binding SelectNewCategoryCommand}" CommandParameter="Movies"/>
        <KeyBinding Key="T" Modifiers="Control" Command="{Binding SelectNewCategoryCommand}" CommandParameter="States"/>
        <KeyBinding Key="U" Modifiers="Control" Command="{Binding SelectNewCategoryCommand}" CommandParameter="Mountains"/>
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding SelectNewCategoryCommand}" CommandParameter="Rivers"/>

        <KeyBinding Key="B" Modifiers="Control" Command="{Binding AboutCommand}"/>
    </Page.InputBindings>
    <Grid Background="Orange">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Menu Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0">
            <MenuItem Header="File">
                <MenuItem Header="New Game" Command="{Binding NewGameCommand}"/>
                <MenuItem Header="Open Game" Command="{Binding OpenGameCommand}"/>
                <MenuItem Header="Save Game" Command="{Binding SaveGameCommand}"/>
                <MenuItem Header="Statistics" Command="{Binding ShowStatisticsCommand}"/>
                <MenuItem Header="Close" Command="{Binding SwitchViewsCommand}" CommandParameter="{x:Type local:MainScreenView}"/>
            </MenuItem>
            <MenuItem Header="Categories" ItemsSource="{Binding CheckedMenuItems}">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding Category}" />
                        <Setter Property="IsCheckable" Value="True"/>
                        <Setter Property="IsChecked" Value="{Binding IsChecked}"/>
                        <Setter Property="Command" Value="{Binding DataContext.SelectNewCategoryCommand, RelativeSource={RelativeSource AncestorType=Page}}"/>
                        <Setter Property="CommandParameter" Value="{Binding Header, RelativeSource={RelativeSource Self}}"/>
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,0,0,0">
            <Label FontSize="20" Content="User:"/>
            <Label FontSize="20" Content="{Binding User.Name}"/>
        </StackPanel>
        <Image Grid.Row="1" Source="{Binding User.ImagePath}" Height="100" Width="100" Margin="70,0,0,0" VerticalAlignment="Top"/>
        <Label Grid.Row="1" FontSize="20" Content="Level:" Margin="10,30,0,0"/>
        <Label Grid.Row="1" FontSize="20" Content="{Binding LevelNumber}" Margin="60,30,0,0"/>
        <Label Grid.Row="1" FontSize="20" Content="Time:" Margin="10,60,0,0"/>
        <Label Grid.Row="1" FontSize="20" Content="{Binding ClockValue}" Margin="60,60,0,0"/>
        <Image Source="{Binding HangmanPath}" Height="200" Width="200" Grid.Row="1" Margin="20,00,0,0"/>
        <ItemsControl ItemsSource="{Binding Lives}" Grid.Column="1" Grid.Row="1" Height="100" Width="350" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,50,10,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                    <Label Width="35" Height="35" Background="LightGray" Content="{Binding Letter}" FontSize="20" HorizontalAlignment="Center" Padding="12,2,0,0"/>
                </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="6"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <Grid Grid.Column="1" Grid.Row="1" Height="140" Width="270" Background="White" HorizontalAlignment="Right" Margin="0,0,50,0">
            <ItemsControl ItemsSource="{Binding Buttons}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button IsEnabled="{Binding IsActive}" Content="{Binding Letter}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" MaxWidth="250"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Grid>
        <Label Content="{Binding WordType}" FontSize="40" Grid.Row="1" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,80"/>
        <ItemsControl ItemsSource="{Binding displayString}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,50">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" FontSize="40" Margin="0,0,15,0"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Page>
